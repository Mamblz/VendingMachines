<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:VendingMachines.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:DataType="vm:AddEditMachinePageViewModel"
             x:Class="VendingMachines.AddEditMachinePage">

	<Grid Background="#f3f4f6">
		<Grid ColumnDefinitions="260,*" RowDefinitions="55,*">

			<Border Grid.RowSpan="2" Background="#111827" Padding="15">
				<StackPanel Spacing="6">
					<TextBlock Text="Навигация" Foreground="#9ca3af" FontSize="14" Margin="5,10"/>
					<Button Content="Главная" Classes="MenuButton"/>
					<Button Content="Монитор ТА" Classes="MenuButton"/>
					<Button Content="Детальные отчеты" Classes="MenuButton"/>
					<Button Content="Учет ТМЦ" Classes="MenuButton"/>
					<TextBlock Text="Администрирование" Foreground="#6b7280" Margin="5,20,5,5"/>
					<Button Content="Торговые автоматы" Classes="MenuButton Active"/>
					<Button Content="Компании" Classes="MenuButton"/>
					<Button Content="Пользователи" Classes="MenuButton"/>
				</StackPanel>
			</Border>

			<Border Grid.Column="1" Background="#1f2937" Padding="20,0">
				<Grid>
					<TextBlock Text="ООО Торговые Автоматы"
                               Foreground="White"
                               VerticalAlignment="Center"
                               FontSize="18"/>
				</Grid>
			</Border>

			<ScrollViewer Grid.Row="1" Grid.Column="1" Margin="25" VerticalScrollBarVisibility="Auto">
				<Border Background="White" CornerRadius="8" Padding="30">
					<StackPanel Spacing="25">

						<TextBlock Text="{Binding PageTitle}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#1F2937"/>

						<Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="20">
							<StackPanel Spacing="15">
								<TextBlock Text="Основная информация" FontSize="16" FontWeight="SemiBold" Foreground="#1F2937"/>
								<Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="15" RowSpacing="15">

									<StackPanel Grid.Row="0" Grid.Column="0">
										<TextBlock Text="Название ТА *" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<TextBox Text="{Binding CompanyLocationName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Watermark="Введите название автомата"
                                                 BorderBrush="#E5E7EB"
                                                 BorderThickness="1"
                                                 CornerRadius="4"
                                                 Padding="8,6"/>
									</StackPanel>

									<StackPanel Grid.Row="0" Grid.Column="1">
										<TextBlock Text="Производитель ТА *" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<ComboBox ItemsSource="{Binding Companies}"
                                                  SelectedItem="{Binding SelectedCompany}"
                                                  DisplayMemberBinding="{Binding Name}"
                                                  PlaceholderText="Выберите производителя"
                                                  BorderBrush="#E5E7EB"
                                                  BorderThickness="1"
                                                  CornerRadius="4"
                                                  Padding="8,6"/>
									</StackPanel>

									<StackPanel Grid.Row="0" Grid.Column="2">
										<TextBlock Text="Модель ТА *" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<ComboBox ItemsSource="{Binding Models}"
                                                  SelectedItem="{Binding SelectedModel}"
                                                  DisplayMemberBinding="{Binding Name}"
                                                  PlaceholderText="Выберите модель"
                                                  BorderBrush="#E5E7EB"
                                                  BorderThickness="1"
                                                  CornerRadius="4"
                                                  Padding="8,6"/>
									</StackPanel>

									<StackPanel Grid.Row="1" Grid.Column="0">
										<TextBlock Text="Режим работы *" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<ComboBox ItemsSource="{Binding WorkModes}"
                                                  SelectedItem="{Binding SelectedWorkMode}"
                                                  DisplayMemberBinding="{Binding Name}"
                                                  PlaceholderText="Выберите режим"
                                                  BorderBrush="#E5E7EB"
                                                  BorderThickness="1"
                                                  CornerRadius="4"
                                                  Padding="8,6"/>
									</StackPanel>

									<StackPanel Grid.Row="1" Grid.Column="1">
										<TextBlock Text="Часовой пояс *" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<ComboBox ItemsSource="{Binding Timezones}"
                                                  SelectedItem="{Binding SelectedTimezone}"
                                                  DisplayMemberBinding="{Binding Name}"
                                                  PlaceholderText="Выберите часовой пояс"
                                                  BorderBrush="#E5E7EB"
                                                  BorderThickness="1"
                                                  CornerRadius="4"
                                                  Padding="8,6"/>
									</StackPanel>

									<StackPanel Grid.Row="1" Grid.Column="2">
										<TextBlock Text="Приоритет обслуживания *" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<ComboBox ItemsSource="{Binding Priorities}"
                                                  SelectedItem="{Binding SelectedPriority}"
                                                  DisplayMemberBinding="{Binding Name}"
                                                  PlaceholderText="Выберите приоритет"
                                                  BorderBrush="#E5E7EB"
                                                  BorderThickness="1"
                                                  CornerRadius="4"
                                                  Padding="8,6"/>
									</StackPanel>
								</Grid>
							</StackPanel>
						</Border>

						<Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="20">
							<StackPanel Spacing="15">
								<TextBlock Text="Расположение" FontSize="16" FontWeight="SemiBold" Foreground="#1F2937"/>
								<Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="15" RowSpacing="15">

									<StackPanel Grid.Row="0" Grid.ColumnSpan="3">
										<TextBlock Text="Адрес *" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<TextBox Text="{Binding CurrentMachine.Location, Mode=TwoWay}"
                                                 Watermark="Введите адрес"
                                                 BorderBrush="#E5E7EB"
                                                 BorderThickness="1"
                                                 CornerRadius="4"
                                                 Padding="8,6"/>
									</StackPanel>

									<StackPanel Grid.Row="1" Grid.Column="0">
										<TextBlock Text="Место *" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<ComboBox ItemsSource="{Binding Places}"
                                                  SelectedItem="{Binding SelectedPlace}"
                                                  DisplayMemberBinding="{Binding Name}"
                                                  PlaceholderText="Выберите место"
                                                  BorderBrush="#E5E7EB"
                                                  BorderThickness="1"
                                                  CornerRadius="4"
                                                  Padding="8,6"/>
									</StackPanel>

									<StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2">
										<TextBlock Text="Координаты" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<TextBox Text="{Binding CurrentMachine.Coordinates, Mode=TwoWay}"
                                                 Watermark="Например: 54.5191, 36.2802"
                                                 BorderBrush="#E5E7EB"
                                                 BorderThickness="1"
                                                 CornerRadius="4"
                                                 Padding="8,6"/>
									</StackPanel>
								</Grid>
							</StackPanel>
						</Border>

						<Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="20">
							<StackPanel Spacing="15">
								<TextBlock Text="Идентификация" FontSize="16" FontWeight="SemiBold" Foreground="#1F2937"/>
								<Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto" ColumnSpacing="15">

									<StackPanel Grid.Column="0">
										<TextBlock Text="Номер автомата *" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<TextBox Text="{Binding CurrentMachine.SerialNumber, Mode=TwoWay}"
                                                 Watermark="Введите номер"
                                                 BorderBrush="#E5E7EB"
                                                 BorderThickness="1"
                                                 CornerRadius="4"
                                                 Padding="8,6"/>
									</StackPanel>

									<StackPanel Grid.Column="1">
										<TextBlock Text="Время работы" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<TextBox Text="{Binding CurrentMachine.WorkingHours, Mode=TwoWay}"
                                                 Watermark="08:00-22:00"
                                                 BorderBrush="#E5E7EB"
                                                 BorderThickness="1"
                                                 CornerRadius="4"
                                                 Padding="8,6"/>
									</StackPanel>

									<StackPanel Grid.Column="2">
										<TextBlock Text="Id кассы Kit Online" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<TextBox Text="{Binding CurrentMachine.KitOnlineId, Mode=TwoWay}"
                                                 Watermark="Только при жесткой привязке"
                                                 BorderBrush="#E5E7EB"
                                                 BorderThickness="1"
                                                 CornerRadius="4"
                                                 Padding="8,6"/>
									</StackPanel>
								</Grid>
							</StackPanel>
						</Border>

						<Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="20">
							<StackPanel Spacing="15">
								<TextBlock Text="Шаблоны и клиенты" FontSize="16" FontWeight="SemiBold" Foreground="#1F2937"/>
								<Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="15" RowSpacing="15">

									<StackPanel Grid.Row="0" Grid.Column="0">
										<TextBlock Text="Шаблон крит. значений" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<ComboBox ItemsSource="{Binding CriticalThresholdTemplates}"
                                                  SelectedItem="{Binding SelectedCriticalThresholdTemplate}"
                                                  DisplayMemberBinding="{Binding Name}"
                                                  PlaceholderText="Выберите шаблон"
                                                  BorderBrush="#E5E7EB"
                                                  BorderThickness="1"
                                                  CornerRadius="4"
                                                  Padding="8,6"/>
									</StackPanel>

									<StackPanel Grid.Row="0" Grid.Column="1">
										<TextBlock Text="Шаблон уведомлений" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<ComboBox ItemsSource="{Binding NotificationTemplates}"
                                                  SelectedItem="{Binding SelectedNotificationTemplate}"
                                                  DisplayMemberBinding="{Binding Name}"
                                                  PlaceholderText="Выберите шаблон"
                                                  BorderBrush="#E5E7EB"
                                                  BorderThickness="1"
                                                  CornerRadius="4"
                                                  Padding="8,6"/>
									</StackPanel>

									<StackPanel Grid.Row="0" Grid.Column="2">
										<TextBlock Text="Клиент" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<ComboBox ItemsSource="{Binding Companies}"
                                                  SelectedItem="{Binding SelectedCompany}"
                                                  DisplayMemberBinding="{Binding Name}"
                                                  PlaceholderText="Выберите клиента"
                                                  BorderBrush="#E5E7EB"
                                                  BorderThickness="1"
                                                  CornerRadius="4"
                                                  Padding="8,6"/>
									</StackPanel>

									<StackPanel Grid.Row="1" Grid.Column="0">
										<TextBlock Text="Менеджер" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<ComboBox ItemsSource="{Binding Managers}"
                                                  SelectedItem="{Binding SelectedManager}"
                                                  DisplayMemberBinding="{Binding FullName}"
                                                  PlaceholderText="Выберите менеджера"
                                                  BorderBrush="#E5E7EB"
                                                  BorderThickness="1"
                                                  CornerRadius="4"
                                                  Padding="8,6"/>
									</StackPanel>

									<StackPanel Grid.Row="1" Grid.Column="1">
										<TextBlock Text="Инженер" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<ComboBox ItemsSource="{Binding Engineers}"
                                                  SelectedItem="{Binding SelectedEngineer}"
                                                  DisplayMemberBinding="{Binding FullName}"
                                                  PlaceholderText="Выберите инженера"
                                                  BorderBrush="#E5E7EB"
                                                  BorderThickness="1"
                                                  CornerRadius="4"
                                                  Padding="8,6"/>
									</StackPanel>

									<StackPanel Grid.Row="1" Grid.Column="2">
										<TextBlock Text="Техник-оператор" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<ComboBox ItemsSource="{Binding Technicians}"
                                                  SelectedItem="{Binding SelectedTechnician}"
                                                  DisplayMemberBinding="{Binding FullName}"
                                                  PlaceholderText="Выберите техника"
                                                  BorderBrush="#E5E7EB"
                                                  BorderThickness="1"
                                                  CornerRadius="4"
                                                  Padding="8,6"/>
									</StackPanel>
								</Grid>
							</StackPanel>
						</Border>

						<Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="20">
							<StackPanel Spacing="15">
								<TextBlock Text="RFID и платежные системы" FontSize="16" FontWeight="SemiBold" Foreground="#1F2937"/>
								<Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="15" RowSpacing="15">

									<StackPanel Grid.Row="0" Grid.Column="0">
										<TextBlock Text="RFID карты обслуживания" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<TextBox Text="{Binding CurrentMachine.RfidService, Mode=TwoWay}"
                                                 Watermark="RFID-SVC-XXXX"
                                                 BorderBrush="#E5E7EB"
                                                 BorderThickness="1"
                                                 CornerRadius="4"
                                                 Padding="8,6"/>
									</StackPanel>

									<StackPanel Grid.Row="0" Grid.Column="1">
										<TextBlock Text="RFID карты инкассации" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<TextBox Text="{Binding CurrentMachine.RfidCashCollection, Mode=TwoWay}"
                                                 Watermark="RFID-CC-XXXX"
                                                 BorderBrush="#E5E7EB"
                                                 BorderThickness="1"
                                                 CornerRadius="4"
                                                 Padding="8,6"/>
									</StackPanel>

									<StackPanel Grid.Row="0" Grid.Column="2">
										<TextBlock Text="RFID карты загрузки" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<TextBox Text="{Binding CurrentMachine.RfidLoading, Mode=TwoWay}"
                                                 Watermark="RFID-LD-XXXX"
                                                 BorderBrush="#E5E7EB"
                                                 BorderThickness="1"
                                                 CornerRadius="4"
                                                 Padding="8,6"/>
									</StackPanel>

									<StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3">
										<TextBlock Text="Платежные системы *" FontSize="13" FontWeight="Medium" Foreground="#4B5563" Margin="0,0,0,4"/>
										<ItemsControl ItemsSource="{Binding PaymentTypes}">
											<ItemsControl.ItemsPanel>
												<ItemsPanelTemplate>
													<WrapPanel Margin="0,4,0,0"/>
												</ItemsPanelTemplate>
											</ItemsControl.ItemsPanel>
											<ItemsControl.ItemTemplate>
												<DataTemplate>
													<CheckBox Content="{Binding Name}"
                                                              IsChecked="{Binding IsSelected}"
                                                              Margin="0,0,15,0"/>
												</DataTemplate>
											</ItemsControl.ItemTemplate>
										</ItemsControl>
									</StackPanel>
								</Grid>
							</StackPanel>
						</Border>

						<Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="20">
							<StackPanel Spacing="15">
								<TextBlock Text="Примечание" FontSize="16" FontWeight="SemiBold" Foreground="#1F2937"/>
								<TextBox Text="{Binding NoteText, Mode=TwoWay}"
                                         Watermark="Введите примечание"
                                         AcceptsReturn="True"
                                         Height="80"
                                         BorderBrush="#E5E7EB"
                                         BorderThickness="1"
                                         CornerRadius="4"
                                         Padding="8,6"/>
							</StackPanel>
						</Border>

						<StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,10,0,0">
							<Button Content="{Binding ButtonText}"
                                    Command="{Binding SaveCommand}"
                                    Width="120"
                                    Height="36"
                                    Background="#2563EB"
                                    Foreground="White"
                                    BorderThickness="0"
                                    CornerRadius="4"
                                    FontWeight="SemiBold"
                                    VerticalContentAlignment="Center"
                                    HorizontalContentAlignment="Center">
								<Button.Styles>
									<Style Selector="Button:pointerover">
										<Setter Property="Background" Value="#1D4ED8"/>
									</Style>
								</Button.Styles>
							</Button>
							<Button Content="Отменить"
                                    Command="{Binding CancelCommand}"
                                    Width="120"
                                    Height="36"
                                    Background="White"
                                    Foreground="#374151"
                                    BorderBrush="#D1D5DB"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    VerticalContentAlignment="Center"
                                    HorizontalContentAlignment="Center">
								<Button.Styles>
									<Style Selector="Button:pointerover">
										<Setter Property="Background" Value="#F9FAFB"/>
									</Style>
								</Button.Styles>
							</Button>
						</StackPanel>

					</StackPanel>
				</Border>
			</ScrollViewer>
		</Grid>
	</Grid>

	<UserControl.Styles>
		<Style Selector="Button.MenuButton">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Foreground" Value="#d1d5db"/>
			<Setter Property="HorizontalAlignment" Value="Stretch"/>
			<Setter Property="CornerRadius" Value="4"/>
			<Setter Property="Padding" Value="10"/>
		</Style>
		<Style Selector="Button.MenuButton:pointerover">
			<Setter Property="Background" Value="#1f2937"/>
		</Style>
		<Style Selector="Button.Active">
			<Setter Property="Background" Value="#2563eb"/>
			<Setter Property="Foreground" Value="White"/>
		</Style>
		<Style Selector="TextBox, ComboBox">
			<Setter Property="BorderBrush" Value="#e5e7eb"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="4"/>
			<Setter Property="Padding" Value="8,6"/>
			<Setter Property="FontSize" Value="14"/>
		</Style>
		<Style Selector="TextBox:focus, ComboBox:focus">
			<Setter Property="BorderBrush" Value="#2563eb"/>
		</Style>
	</UserControl.Styles>
</UserControl>